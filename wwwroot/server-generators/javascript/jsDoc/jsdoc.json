{
    "tags": {
        "allowUnknownTags": true,
        "dictionaries": ["jsdoc"]
    },
	"plugins": [
        "jsdoc/plugins/markdown",
        "jsdoc/plugins/summarize",
		"jsdoc/plugins/commentConvert",
		"jsdoc/plugins/escapeHtml",
		"jsdoc/plugins/overloadHelper",
		"jsdoc/plugins/partial",
		"jsdoc/plugins/railsTemplate",
		"jsdoc/plugins/shout",
		"jsdoc/plugins/sourcetag",
		"jsdoc/plugins/underscore"
    ],
    "source": {
        "include": [
            "manage/js/global-storage.js",
			"manage/js/global-behavior.js",
			"manage/js/global-functions.js",
			"manage/js/global-api.js",
			"manage/js/global-media.js",
			"manage/js/global-object.js",
			"manage/js/global-signalr.js",
			"manage/js/global-socket.js"
        ]
    },
    "opts": {
        "encoding": "utf8",
        "destination": "./doc/",
		"private": true,
        "recurse": true,
        "readme": "Readme.md",
		"template": "jsdoc/templates/default"
    }
}
