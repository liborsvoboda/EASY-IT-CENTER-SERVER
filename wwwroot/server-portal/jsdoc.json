{
    "tags": {
        "allowUnknownTags": true,
        "dictionaries": ["jsdoc"]
    },
  "plugins": [
    "jsdoc/plugins/markdown",
    "jsdoc/plugins/summarize",
    "jsdoc/plugins/commentConvert",
    "jsdoc/plugins/escapeHtml",
    "jsdoc/plugins/overloadHelper",
    "jsdoc/plugins/partial",
    "jsdoc/plugins/railsTemplate",
    "jsdoc/plugins/shout",
    "jsdoc/plugins/sourcetag",
    "jsdoc/plugins/underscore"
  ],
    "source": {
      "include": [
        "manage/js/global-desktop.js",
        "manage/js/global-database.js",
        "manage/js/global-direct.js",
        "manage/js/global-storage.js",
        "manage/js/global-behavior.js",
        "manage/js/global-functions.js",
        "manage/js/global-api.js",
        "manage/js/global-media.js",
        "manage/js/global-object.js",
        "manage/js/global-signalr.js",
        "manage/js/global-socket.js",
        "manage/js/global-generator.js"
      ]
    },
  "opts": {
    "encoding": "utf8",
    "destination": "./GsFrameWorkDocs/",
    //"private": true,
    "recurse": true,
    "readme": "Readme.md",
    //"template": "addons/jsdoc/templates/default",
    "theme_opts": {
      "title": "EIC Javascript Library",
      "meta": [
        "<title>EIC Javascript Library</title>",
        "<meta name=\"author\" content=\"Libor Svoboda\">",
        "<meta name=\"description\" content=\"Documentation for EIC Server Portal for Global Functions of Negerated portaL\">"
      ],
      "menu": [
        {
          "title": "Website",
          "link": "https://KlikneteZde.Cz"
        },
        {
          "title": "Github",
          "link": "https://KlikneteZde.Cz"
        },
        {
          "title": "Demo",
          "link": "https://KlikneteZde.Cz"
        }
      ]
    }
  }
}
