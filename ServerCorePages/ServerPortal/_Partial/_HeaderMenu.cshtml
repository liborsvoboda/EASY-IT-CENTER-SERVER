        <div class="app-bar-container">
            <a href="#" class="app-bar-item shadowed">
                <img src="/server-portal/images/logo.png" class="avatar">
                    <span id="LoginName" class="ml-2 app-bar-name"></span>
            </a>
            <div class="user-block shadow-1" data-role="collapse" data-collapsed="true">
                <div class="bg-darkCyan fg-white p-2 text-middle">
                    <img src="/server-portal/images/logo.png" class="avatar">
                    <div class="h4 mb-0"></div>
                </div>
                <div class="bg-white d-flex flex-justify-between flex-equal-items p-2">
                    <button class="button flat-button">News</button>
                    <button class="button flat-button">ChangeLog</button>
                    <button class="button flat-button">Notes</button>
                </div>
                <div id="LoginReaction" class="bg-white d-flex flex-justify-between flex-equal-items p-2 bg-light">
